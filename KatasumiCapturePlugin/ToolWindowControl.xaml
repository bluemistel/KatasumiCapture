<UserControl x:Class="ClipboardToTimelinePlugin.ToolWindowControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="360" d:DesignWidth="300"
             MinWidth="280">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- キャプチャ操作（アイコン + 短いテキスト） -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
            <Button ToolTip="画面をドラッグして範囲選択し、設定に従ってコピー／貼り付けします"
                    Command="{Binding CaptureRegionCommand}"
                    Padding="6,4" Margin="0,0,6,0" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE722;" FontSize="18" VerticalAlignment="Center"/>
                    <TextBlock Text="範囲" Margin="6,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Button>
            <Button ToolTip="前回と同じ矩形でキャプチャします（Shift+基本キーと同じ）"
                    Command="{Binding CaptureRepeatCommand}"
                    Padding="6,4" Margin="0,0,10,0" Cursor="Hand">
                <StackPanel Orientation="Horizontal">
                    <Grid Width="24" Height="20" VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE722;" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE149;" FontSize="11" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,-4,-2"/>
                    </Grid>
                    <TextBlock Text="再撮影" Margin="4,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Button>
            <CheckBox Content="キー操作無効"
                      IsChecked="{Binding HotkeysSuppressed, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      ToolTip="ONにするとキーボードショートカットは効きません（誤操作防止）。上のボタンは使用できます。"/>
        </StackPanel>

        <TextBlock Grid.Row="1" Text="出力" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <StackPanel Grid.Row="2" Margin="0,0,0,8">
            <RadioButton Margin="0,0,0,6" IsChecked="{Binding IsClipboardCopyEnabled, Mode=TwoWay}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8C8;" FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="クリップボードへコピー" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </RadioButton>
            <RadioButton IsChecked="{Binding IsDirectTimelinePasteEnabled, Mode=TwoWay}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE724;" FontSize="15" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="コピーして画像アイテムとして送る" VerticalAlignment="Center" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </RadioButton>
        </StackPanel>

        <CheckBox Grid.Row="3" Content="画像も保存する"
                  IsChecked="{Binding SaveImageToDirectory, Mode=TwoWay}"
                  Margin="0,0,0,4"/>

        <Grid Grid.Row="4" IsEnabled="{Binding SaveImageToDirectory}" Margin="4,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0"
                     Text="{Binding SaveDirectoryPath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     MinHeight="22"
                     VerticalContentAlignment="Center"
                     Margin="0,0,4,0"
                     ToolTip="保存をONにしたときのみ有効。空欄のままだと保存せずクリップボードのみ（直接貼り付けモード時）。"/>
            <Button Grid.Column="1"
                    Click="BrowseSaveFolder_Click"
                    Padding="8,4"
                    MinWidth="36"
                    ToolTip="保存先フォルダを選択"
                    Cursor="Hand">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8DA;" FontSize="16"/>
            </Button>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="基本キー" VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
            <ComboBox Width="52"
                      ItemsSource="{Binding HotkeyKeyCandidates}"
                      SelectedItem="{Binding HotkeyKeyLetter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      VerticalAlignment="Center"/>
            <TextBlock Text="+ Shift で再撮影" VerticalAlignment="Center" Margin="8,0,0,0" FontSize="11"
                       Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"/>
        </StackPanel>

        <!-- 前景色・背景色は固定せずホスト（YMM4）のテーマを継承。枠線のみシステムブラシ -->
        <Border Grid.Row="6"
                BorderThickness="1"
                Padding="8"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}">
            <TextBlock TextWrapping="Wrap" FontSize="11"
                       Text="ショートカットは YMM4 のウィンドウがアクティブなときだけ有効です。「キー操作無効」にするとキーボードからは実行されません。"/>
        </Border>
    </Grid>
</UserControl>
